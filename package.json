{
  "name": "suaontologyviztool",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:cov": "vitest run --coverage --passWithNoTests",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "ci:local": "npm run lint && npm run type-check && npm run test:cov && npm run build"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "cytoscape": "^3.34.0",
    "cytoscape-expand-collapse": "^4.1.1",
    "html-to-image": "^1.11.13",
    "jsonld": "^9.0.0",
    "jspdf": "^4.2.1",
    "n3": "^2.1.1",
    "rdfxml-streaming-parser": "^3.2.0",
    "react": "^19.2.7",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "^19.2.7",
    "readable-stream": "^4.7.0",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jsonld": "^1.5.15",
    "@types/n3": "^1.26.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vitest": "^4.1.10"
  }
}
